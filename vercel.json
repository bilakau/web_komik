{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/series/(.*)", "destination": "/public/index.html" },
    { "source": "/chapter/(.*)", "destination": "/public/index.html" },
    { "source": "/latest", "destination": "/public/index.html" },
    { "source": "/latest/(.*)", "destination": "/public/index.html" },
    { "source": "/library", "destination": "/public/index.html" },
    { "source": "/library/(.*)", "destination": "/public/index.html" },
    { "source": "/genre/(.*)", "destination": "/public/index.html" },
    { "source": "/search", "destination": "/public/index.html" },
    { "source": "/history", "destination": "/public/index.html" },
    { "source": "/bookmarks", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
